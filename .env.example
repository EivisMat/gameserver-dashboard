# --- Dashboard ---
# Port the dashboard's HTTP server binds to (behind a reverse proxy in production).
PORT=3001

# Generated automatically by `node setup.js` on first run. Don't share.
# JWT_SECRET=

# --- Pterodactyl Panel ---
# Base URL of your Pterodactyl panel (no trailing slash).
PTERO_URL=https://panel.example.com

# Application API key (panel admin -> Application API). Used for server CRUD,
# allocation management, egg inspection.
PTERO_APP_KEY=

# Client API key (your user -> Account API). Used for console, file ops, backups.
PTERO_CLIENT_KEY=

# Pterodactyl user ID that owns servers created through the dashboard.
# Defaults to 1 (the panel's first admin).
PTERO_DEFAULT_USER_ID=1

# --- Wings node ---
# Public IP of the Wings node. Used when creating allocations and as the
# host shown in the server-detail "Address" stat. Required.
NODE_PUBLIC_IP=

# --- WireGuard (admin peer self-service) ---
# Path to the privileged helper script. The dashboard user must have a sudoers
# entry allowing NOPASSWD execution of this script (see README).
WG_HELPER_PATH=/opt/dashboard/wg-helper.sh

# UDP port WireGuard listens on (matches your wg0.conf ListenPort).
WG_LISTEN_PORT=51820

# Subnet the dashboard hands out peer IPs from. CIDR form. The /24 is assumed
# in the next-IP loop, so don't drop below /24 without code changes.
WG_SUBNET=10.8.0.0/24

# --- Activity log + state watcher ---
# Max activity rows kept per server; oldest evicted on insert. 0 = no cap.
ACTIVITY_RETENTION_PER_SERVER=100

# Poll interval for the crash / auto-restart detector. Lower = faster
# detection, more API calls to Pterodactyl.
STATE_POLL_INTERVAL_SEC=15

# --- Modpack search (optional) ---
# CurseForge developer API key. Without it, only Modrinth modpacks work.
# https://console.curseforge.com/
CURSEFORGE_API_KEY=
